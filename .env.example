# ── Next.js app (Vercel) ─────────────────────────────────────────────
# Both values are PUBLIC by design (they ship to every browser; RLS is the
# security boundary). Committed defaults live in lib/publicConfig.ts; set
# these only to point at a different Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://fxrnuoahfzzdsepwvzux.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets)
# The service-role key is INJECTED automatically — never set it manually,
# never put it here, never put it on Vercel.

# LLM provider. Default is "mock" (deterministic, $0). Set both to go real:
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=...

# Discussion source for Stage 2. Default "synthetic" (labeled). Reddit path
# needs credentials + a small provider implementation (seam is ready):
# DISCUSSION_PROVIDER=reddit

# Stripe TEST mode (billing runs in labeled sandbox mode until these exist):
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_FOUNDER=price_...
# APP_URL=https://everdeck-psi.vercel.app

# Worker tuning:
# TICK_BATCH=6
